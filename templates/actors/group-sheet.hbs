<form class="wet-sheet wet-group-sheet {{cssClass}}" autocomplete="off">
  <header class="wet-sheet__header">
    <div class="wet-sheet__portrait">
      <img
        class="wet-sheet__portrait-image"
        src="{{actor.img}}"
        alt="{{actor.name}}"
      >
    </div>

    <div class="wet-sheet__header-fields">
      <div class="wet-field">
        <label class="wet-field__label" for="{{rootId}}-name">
          {{localize "WET.Sheets.Common.Fields.Name"}}
        </label>
        <input
          id="{{rootId}}-name"
          class="wet-field__input wet-field__input--title"
          type="text"
          name="name"
          value="{{actor.name}}"
          placeholder="{{localize "WET.Sheets.Group.Placeholders.Name"}}"
          {{#unless editable}}disabled{{/unless}}
        >
      </div>

      <div class="wet-sheet__meta">
        <span class="wet-pill">{{actorTypeLabel}}</span>
      </div>
    </div>
  </header>

  <section class="wet-sheet__section">
    <h2 class="wet-sheet__section-title">
      {{localize "WET.Sheets.Group.Sections.Basics"}}
    </h2>

    <div class="wet-grid wet-grid--two">
      <div class="wet-field">
        <label class="wet-field__label" for="{{rootId}}-status">
          {{localize "WET.Sheets.Group.Fields.Status"}}
        </label>
        <input
          id="{{rootId}}-status"
          class="wet-field__input"
          type="text"
          name="system.details.status"
          value="{{system.details.status}}"
          placeholder="{{localize "WET.Sheets.Group.Placeholders.Status"}}"
          {{#unless editable}}disabled{{/unless}}
        >
      </div>

      <div class="wet-field">
        <label class="wet-field__label" for="{{rootId}}-location">
          {{localize "WET.Sheets.Group.Fields.Location"}}
        </label>
        <input
          id="{{rootId}}-location"
          class="wet-field__input"
          type="text"
          name="system.details.location"
          value="{{system.details.location}}"
          placeholder="{{localize "WET.Sheets.Group.Placeholders.Location"}}"
          {{#unless editable}}disabled{{/unless}}
        >
      </div>
    </div>
  </section>

  <section class="wet-sheet__section">
    <h2 class="wet-sheet__section-title">
      {{localize "WET.Sheets.Group.Sections.Description"}}
    </h2>

    <div class="wet-field">
      <textarea
        id="{{rootId}}-description"
        class="wet-field__textarea"
        name="system.summary.description"
        placeholder="{{localize "WET.Sheets.Group.Placeholders.Description"}}"
        rows="6"
        {{#unless editable}}disabled{{/unless}}
      >{{system.summary.description}}</textarea>
    </div>
  </section>

  <section class="wet-sheet__section">
    <h2 class="wet-sheet__section-title">
      {{localize "WET.Sheets.Group.Sections.Notes"}}
    </h2>

    <div class="wet-field">
      <textarea
        id="{{rootId}}-notes"
        class="wet-field__textarea"
        name="system.summary.notes"
        placeholder="{{localize "WET.Sheets.Group.Placeholders.Notes"}}"
        rows="8"
        {{#unless editable}}disabled{{/unless}}
      >{{system.summary.notes}}</textarea>
    </div>
  </section>
</form>